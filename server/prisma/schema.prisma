// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Temporary compilation placeholder required by the Prisma compiler to generate the client.
// This model is NEVER pushed or migrated to the database in Phase 1.
model CompilePlaceholder {
  id Int @id @default(autoincrement())
}
